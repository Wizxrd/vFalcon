<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Resources\Images\vFalcon.ico</ApplicationIcon>
    <Version>0.0.9</Version>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="ARTTCs\**" />
    <Compile Remove="Logs\**" />
    <Compile Remove="VideoMaps\**" />
    <EmbeddedResource Remove="ARTTCs\**" />
    <EmbeddedResource Remove="Logs\**" />
    <EmbeddedResource Remove="VideoMaps\**" />
    <None Remove="ARTTCs\**" />
    <None Remove="Logs\**" />
    <None Remove="VideoMaps\**" />
    <Page Remove="ARTTCs\**" />
    <Page Remove="Logs\**" />
    <Page Remove="VideoMaps\**" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Resources\Images\vFalcon.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AdonisUI" Version="1.17.1" />
    <PackageReference Include="AdonisUI.ClassicTheme" Version="1.17.1" />
    <PackageReference Include="CommunityToolkit.HighPerformance" Version="8.4.0" />
    <PackageReference Include="Extended.Wpf.Toolkit" Version="4.7.25104.5739" />
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" Version="1.1.135" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="SkiaSharp" Version="3.119.0" />
    <PackageReference Include="SkiaSharp.Views.WPF" Version="3.119.0" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Models\" />
    <Folder Include="ARTCCs\" />
    <Folder Include="Profiles\" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Images\vFalcon.ico" />
  </ItemGroup>

</Project>
